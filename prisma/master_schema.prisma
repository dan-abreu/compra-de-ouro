generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/master-client"
}

datasource db {
  provider = "postgresql"
  url      = env("MASTER_DATABASE_URL")
}

enum LicenseStatus {
  ACTIVE
  INACTIVE
}

model Tenant {
  id            String        @id @default(cuid())
  companyName   String        @db.VarChar(180)
  licenseStatus LicenseStatus @default(ACTIVE)
  databaseUrl   String        @unique @db.VarChar(2000)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([licenseStatus])
  @@index([companyName])
}
