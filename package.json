{
  "name": "compra-de-ouro-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test src/**/*.test.ts",
    "test:stress:read": "node logs/stress-test.mjs",
    "test:stress:write": "node logs/stress-test-write.mjs",
    "test:stress:ramp": "node logs/stress-test-ramp.mjs",
    "validate:migration": "tsx src/scripts/validate-migration.ts",
    "provision:tenant": "tsx src/scripts/provision-new-tenant.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:master": "prisma generate --schema prisma/master_schema.prisma",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "prisma": "^6.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
